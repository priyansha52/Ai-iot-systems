#define BLYNK_TEMPLATE_ID "YOUR_TEMPLATE_ID"
#define BLYNK_TEMPLATE_NAME "Home Automation"
#define BLYNK_AUTH_TOKEN "YOUR_AUTH_TOKEN"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>

char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "YOUR_WIFI_PASSWORD";

#define RELAY1 26
#define RELAY2 27
#define IR_SENSOR 34

bool bulb1Manual = false;
bool bulb2Manual = false;

// Bulb 1 Manual Control
BLYNK_WRITE(V1)
{
  bulb1Manual = param.asInt();

  if (bulb1Manual)
    digitalWrite(RELAY1, LOW);
  else
    digitalWrite(RELAY1, HIGH);
}

// Bulb 2 Manual Control
BLYNK_WRITE(V2)
{
  bulb2Manual = param.asInt();

  if (bulb2Manual)
    digitalWrite(RELAY2, LOW);
  else
    digitalWrite(RELAY2, HIGH);
}

void setup()
{
  Serial.begin(115200);

  pinMode(RELAY1, OUTPUT);
  pinMode(RELAY2, OUTPUT);
  pinMode(IR_SENSOR, INPUT);

  digitalWrite(RELAY1, HIGH);
  digitalWrite(RELAY2, HIGH);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
}

void loop()
{
  Blynk.run();

  int irState = digitalRead(IR_SENSOR);

  if (irState == LOW)   // Person detected
  {
    digitalWrite(RELAY1, LOW);   // Bulb 1 ON
    digitalWrite(RELAY2, LOW);   // Bulb 2 ON

    Serial.println("Person Detected - Both Bulbs ON");
  }
  else
  {
    // Return control to Blynk switches
    digitalWrite(RELAY1, bulb1Manual ? LOW : HIGH);
    digitalWrite(RELAY2, bulb2Manual ? LOW : HIGH);
  }
}
